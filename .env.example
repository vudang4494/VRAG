# VRAG — environment configuration template.
# Copy to .env and fill in the secrets:  cp .env.example .env
#
# ─── READ THIS BEFORE ADDING A LINE ───────────────────────────────────
# src/config.py is the ONE source of truth for every default. This file
# deliberately does NOT restate them.
#
# Why: this template used to carry its own copy of the tuning defaults, and they
# drifted away from src/config.py without anyone noticing — OLLAMA_MODEL pinned to
# a model that was not installed, PII_LLM_NER_ENABLED=1 against a code default of 0
# (a 62x ingest cost), CONTEXT_COMPRESSION_ENABLED=1 against 0, and all three
# validation thresholds disagreeing. Every .env copied from this template inherited
# the drift, so no evaluation run on such a box measured the configuration the code
# claimed to have. Restating a default here is how that happens; do not do it.
#
# So: everything below the secrets block stays COMMENTED OUT. Uncomment a line only
# to deliberately override src/config.py. The startup config banner prints every
# value that differs from the code default, so an override is visible, not silent.
#
# Prefer a shell override when it is temporary:
#     PII_LLM_NER_ENABLED=0 make up
# ──────────────────────────────────────────────────────────────────────

# ─── Required: passwords + secrets ────────────────────────────────────
POSTGRES_PASSWORD=changeme_postgres
REDIS_PASSWORD=changeme_redis
GRAFANA_PASSWORD=changeme_grafana
CLICKHOUSE_PASSWORD=changeme_clickhouse
NEO4J_PASSWORD=changeme_neo4j

# Langfuse — generate with: openssl rand -hex 32
LANGFUSE_DB_PASSWORD=changeme_langfuse_db
LANGFUSE_ADMIN_PASSWORD=changeme_langfuse_admin
LANGFUSE_NEXTAUTH_SECRET=changeme_random_64_hex_chars
LANGFUSE_SALT=changeme_random_32_hex_chars
LANGFUSE_ENCRYPTION_KEY=changeme_random_64_hex_chars

# Public/secret key pair created when you sign in to Langfuse UI for the first time.
# Leave blank initially; set after creating a Langfuse project.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Open WebUI session secret — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme_random_64_hex_chars

# Admin contact (Langfuse signup)
ADMIN_EMAIL=admin@example.com

# Internal API key (rotate periodically)
API_INTERNAL_KEY=changeme_random_64_hex_chars

# ─── Optional overrides — COMMENTED ON PURPOSE ────────────────────────
# Defaults live in src/config.py. A value shown in a comment below is the code
# default at the time of writing, for orientation only. If it ever disagrees with
# src/config.py, src/config.py wins and the comment is the bug.
#
# See docs/ARCHITECTURE.md § 11 for the quality vs latency trade-offs.

# LLM. Set all three together: ollama_model does NOT inherit HEAVY_LLM, and it is
# the fallback for every ollama_chat() call made without an explicit model=.
# Verify the tag exists (`ollama list`) BEFORE setting — a missing tag does not
# fail at startup, it fails at the first intent-classification call.
# LIGHT_LLM=gemma4:e4b
# HEAVY_LLM=gemma4:e4b
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_EMBED_MODEL=bge-m3          # 1024-dim; must match the Qdrant collection
# LOG_LEVEL=INFO

# Tier 1: zero-LLM by default. Raise (1-5) to add query reformulations.
# QUERY_REFORMULATIONS=0
# QUERY_UNDERSTANDING_TIMEOUT_S=60

# Tier 3b: cross-encoder rerank + dynamic early-exit.
# TRAP: RERANK_STAGE1_ENABLED=1 is NOT sufficient to turn stage 1 on today —
# sentence-transformers is commented out of api/requirements.txt, so the import
# fails, the error is swallowed, and the stage is skipped. Install the dep first
# or this flag is a placebo.
# RERANK_STAGE1_ENABLED=0
# RERANK_STAGE3_ENABLED=0
# RERANK_EARLY_EXIT_THRESHOLD=0.85

# Tier 3c: LLMLingua-2 context compression.
# The `llmlingua` dep IS installed (api/requirements.txt), so this flag works —
# unlike RERANK_STAGE1_ENABLED above. First call downloads a ~600MB model from HF.
# CONTEXT_COMPRESSION_ENABLED=0
# CONTEXT_COMPRESSION_RATE=0.4

# Tier 4: generation knobs
# GENERATION_DRAFTS=1
# GENERATION_OUTLINE_ENABLED=0
# GENERATION_JUDGE_ENABLED=0
# GENERATION_REFINE_ENABLED=0

# Triple-Gate validation thresholds
# VALIDATION_MIN_GROUNDED_RATIO=0.70
# VALIDATION_MAX_INVALID_ENTITIES=3
# VALIDATION_MIN_CITATION_RATIO=0.70

# Ingestion knobs.
# PII_LLM_NER_ENABLED=1 costs roughly 62x ingest time on a gemma-class model
# (measured: regex pass 5.1ms vs LLM pass 339s on the same document). The regex
# pass already masks phone/email/ID/account. Only enable it with a fast GPU model.
# PII_MASK_ENABLED=1
# PII_LLM_NER_ENABLED=0
# CONSISTENCY_VIEWS_ENABLED=1        # also the low-quality-chunk filter — off = no filter
# DOC_CONTEXT_PREFIX_ENABLED=1
# ENTITY_VOTE_PASSES=3
# ENTITY_EXTRACTOR_PROVIDER=gliner   # `disabled` only stops the INGEST path; the query
#                                    # path hardcodes GLiNER and still loads torch
# ENTITY_EXTRACTOR_MODEL=urchade/gliner_multi-v2.1
# ENTITY_EXTRACTOR_THRESHOLD=0.5
# CHUNK_LEVELS_ENABLED=paragraph,section

# Optional features
# COMMUNITY_ENABLED=0
