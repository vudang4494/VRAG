# VRAG — environment configuration template.
# Copy to .env and fill in the secrets. The .env file is gitignored.

# ─── Required: passwords + secrets ────────────────────────────────────
POSTGRES_PASSWORD=changeme_postgres
REDIS_PASSWORD=changeme_redis
GRAFANA_PASSWORD=changeme_grafana
CLICKHOUSE_PASSWORD=changeme_clickhouse

# Langfuse — generate with: openssl rand -hex 32
LANGFUSE_DB_PASSWORD=changeme_langfuse_db
LANGFUSE_ADMIN_PASSWORD=changeme_langfuse_admin
LANGFUSE_NEXTAUTH_SECRET=changeme_random_64_hex_chars
LANGFUSE_SALT=changeme_random_32_hex_chars
LANGFUSE_ENCRYPTION_KEY=changeme_random_64_hex_chars

# Public/secret key pair created when you sign in to Langfuse UI for the first time.
# Leave blank initially; set after creating a Langfuse project.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Open WebUI session secret — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme_random_64_hex_chars

# Admin contact (Langfuse signup)
ADMIN_EMAIL=admin@example.com

# Internal API key (rotate periodically)
API_INTERNAL_KEY=changeme_random_64_hex_chars

# ─── Optional: model + pipeline tuning ────────────────────────────────
# See ARCHITECTURE.md § 11 for quality vs latency trade-offs.

OLLAMA_MODEL=qwen3.5:9b
LOG_LEVEL=INFO

# Tier 1: zero-LLM by default. Raise (1-5) to add query reformulations.
QUERY_REFORMULATIONS=0
QUERY_UNDERSTANDING_TIMEOUT_S=60

# Tier 3b: cross-encoder rerank + dynamic early-exit
RERANK_STAGE1_ENABLED=0
RERANK_STAGE3_ENABLED=0
RERANK_EARLY_EXIT_THRESHOLD=0.85

# Tier 3c: LLMLingua-2 context compression
CONTEXT_COMPRESSION_ENABLED=1
CONTEXT_COMPRESSION_RATE=0.4

# Tier 4: generation knobs
GENERATION_DRAFTS=1
GENERATION_OUTLINE_ENABLED=0
GENERATION_JUDGE_ENABLED=0

# Triple-Gate validation thresholds
VALIDATION_MIN_GROUNDED_RATIO=0.80
VALIDATION_MAX_INVALID_ENTITIES=2
VALIDATION_MIN_CITATION_RATIO=0.40

# Ingestion knobs
CONSISTENCY_VIEWS_ENABLED=1
ENTITY_VOTE_PASSES=3
ENTITY_EXTRACTOR_PROVIDER=gliner
ENTITY_EXTRACTOR_MODEL=urchade/gliner_multi-v2.1
ENTITY_EXTRACTOR_THRESHOLD=0.5
CHUNK_LEVELS_ENABLED=paragraph,section

# PII masking
PII_MASK_ENABLED=1
PII_LLM_NER_ENABLED=1

# Optional features
COMMUNITY_ENABLED=0
