# ── Secrets ─────────────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Internal / strategic documentation (Claude Code workspace) ──────────
.claude/
CLAUDE.md

# ── Backups + state ─────────────────────────────────────────────────────
backups/

# ── SSL certs (private keys) ────────────────────────────────────────────
ssl/*.pem
ssl/*.key
ssl/*.crt

# ── Logs ────────────────────────────────────────────────────────────────
*.log
logs/

# ── Eval result dumps ───────────────────────────────────────────────────
# Track .md reports (proof of evaluation runs); ignore raw .json dumps + logs.
eval/results/*.log
eval/results/tmp_*
eval/results/*.json
*.eval.json

# ── Large corpus / source documents (not for git) ───────────────────────
# Research papers and ingest source files — too large to track. Document
# how to obtain in README. Use volume mount or external storage.
data/eval/*.pdf
data/eval/*.docx
data/eval/*.xlsx
data/raw/

# ── Local intent centroids (rebuild via scripts/build_intent_centroids.py) ─
# Bundled into container image at build time; track the file once stable.
# Uncomment to ignore if you rebuild frequently:
# config/intent_centroids.npy

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/

# ── HuggingFace model cache ─────────────────────────────────────────────
.cache/

# ── IDE ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker overrides ────────────────────────────────────────────────────
docker-compose.override.yml
